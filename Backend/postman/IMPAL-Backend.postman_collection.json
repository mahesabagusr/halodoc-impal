{
  "info": {
    "name": "IMPAL Backend API",
    "_postman_id": "8ee60906-4dda-4b17-9558-438ddd31d5f9",
    "description": "Collection for all current IMPAL backend APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "patientEmail",
      "value": "patient@example.com"
    },
    {
      "key": "patientPassword",
      "value": "password123"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "patientToken",
      "value": ""
    },
    {
      "key": "cartItemId",
      "value": "1"
    },
    {
      "key": "productId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Server",
      "item": [
        {
          "name": "Root Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Basic server status endpoint."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Users Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "health"]
            }
          }
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Patient\",\n  \"email\": \"{{patientEmail}}\",\n  \"password\": \"{{patientPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json?.data?.token;",
                  "if (token) {",
                  "  pm.collectionVariables.set('patientToken', token);",
                  "  pm.collectionVariables.set('accessToken', token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patientEmail}}\",\n  \"password\": \"{{patientPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "login"]
            }
          }
        },
        {
          "name": "Edit User (Not Implemented)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated Name\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/edit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "edit"]
            },
            "description": "Currently returns feature not implemented."
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"]
            },
            "description": "Requires ADMIN role token. Set adminToken manually."
          }
        }
      ]
    },
    {
      "name": "Pharmacy",
      "item": [
        {
          "name": "Get My Cart",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pharmacy/cart",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "pharmacy", "cart"]
            }
          }
        },
        {
          "name": "Add Item To Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/pharmacy/cart/items",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "pharmacy", "cart", "items"]
            }
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pharmacy/cart/items/{{cartItemId}}",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "v1",
                "pharmacy",
                "cart",
                "items",
                "{{cartItemId}}"
              ]
            }
          }
        },
        {
          "name": "Checkout Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"Jl. Contoh No. 123, Jakarta\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/pharmacy/cart/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "pharmacy", "cart", "checkout"]
            }
          }
        }
      ]
    }
  ]
}
